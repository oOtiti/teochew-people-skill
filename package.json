{
  "name": "teochew-people-skill",
  "version": "0.1.1",
  "description": "Teochew People (潮汕人) writing and review skill for AI agents.",
  "license": "MIT",
  "author": "oOtiti",
  "homepage": "https://github.com/oOtiti/teochew-people-skill#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oOtiti/teochew-people-skill.git"
  },
  "bugs": {
    "url": "https://github.com/oOtiti/teochew-people-skill/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "teochew-people-skill": "scripts/install-skill.mjs"
  },
  "files": [
    "skills/teochew-people-skill",
    "scripts/install-skill.mjs",
    "examples",
    "assets/social-preview.png",
    "assets/case-demo.svg",
    "docs",
    "README.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "scripts": {
    "install:codex": "node scripts/install-skill.mjs --codex --force",
    "install:claude": "node scripts/install-skill.mjs --claude --force",
    "validate": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/validate-skill.ps1",
    "test": "npm run validate",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "agent-skill",
    "codex-skill",
    "claude-code-skill",
    "chaoshan",
    "teochew",
    "teochew-people",
    "潮汕",
    "潮汕人",
    "潮汕文化",
    "中文写作"
  ],
  "engines": {
    "node": ">=18"
  }
}
