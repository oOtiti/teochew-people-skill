#!/usr/bin/env sh
set -eu

ROOT="$(git rev-parse --show-toplevel)"
VALIDATOR="$ROOT/scripts/validate-skill.ps1"
PS_VALIDATOR="$VALIDATOR"

if command -v cygpath >/dev/null 2>&1; then
  PS_VALIDATOR="$(cygpath -w "$VALIDATOR")"
elif command -v wslpath >/dev/null 2>&1; then
  PS_VALIDATOR="$(wslpath -w "$VALIDATOR")"
fi

if command -v pwsh >/dev/null 2>&1; then
  pwsh -NoProfile -ExecutionPolicy Bypass -File "$PS_VALIDATOR"
elif command -v powershell.exe >/dev/null 2>&1; then
  powershell.exe -NoProfile -ExecutionPolicy Bypass -File "$PS_VALIDATOR"
else
  echo "PowerShell is required to run scripts/validate-skill.ps1" >&2
  exit 1
fi
